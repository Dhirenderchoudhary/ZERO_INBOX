# ─── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Corsair SDK ───────────────────────────────────────────────
CORSAIR_KEK="your-corsair-key-encryption-key"
TENANT_ID="your-corsair-tenant-id"

# ─── Authentication ───────────────────────────────────────────
BETTER_AUTH_SECRET="your-auth-secret-min-32-chars"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI ────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Upstash (Optional — enables caching + rate limiting) ─────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── QStash (Optional — enables durable background jobs) ──────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─── Razorpay (Optional — enables billing) ────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
